    "Header": "src/components/layout/Header.tsx",
    "NavBar": "src/components/layout/NavBar.tsx",
    "Sidebar": "src/components/layout/Sidebar.tsx",
    "SyncStatus": "src/components/layout/SyncStatus.tsx",
    "CompactCard": "src/components/task/CompactCard.tsx",
    "DeferMenu": "src/components/task/DeferMenu.tsx",
    "TaskCard": "src/components/task/TaskCard.tsx",
    "TaskMeta": "src/components/task/TaskMeta.tsx",
    "TaskStack": "src/components/task/TaskStack.tsx",
    "AllView": "src/components/views/AllView.tsx",
    "DetailView": "src/components/views/DetailView.tsx",
