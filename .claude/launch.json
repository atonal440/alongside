{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "worker",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/wrangler", "dev"],
      "port": 8787,
      "cwd": "worker"
    },
    {
      "name": "pwa",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["/tmp/serve-tool/node_modules/.bin/serve", "pwa"],
      "port": 3000
    },
    {
      "name": "pwa-dev",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/vite", "--port", "5173"],
      "port": 5173,
      "cwd": "pwa"
    }
  ]
}
